{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node -r dotenv/config dist/index.js",
    "dev": "pnpm --filter=@repo/db run db:generate && tsx watch --require dotenv/config src/index.ts | pino-pretty",
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@react-email/components": "^1.0.6",
    "@react-email/render": "^2.0.4",
    "@repo/db": "workspace:*",
    "@repo/validation": "workspace:*",
    "axios": "^1.13.2",
    "bullmq": "^5.9.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "openid-client": "^6.8.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "react-email": "^5.2.5",
    "resend": "^6.4.2",
    "voyageai": "^0.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "eslint": "^9.7.0",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^11.2.1",
    "tsup": "8.2.3",
    "tsx": "4.16.2",
    "typescript": "5.9.2"
  }
}
